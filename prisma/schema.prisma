// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String?
  name       String?
  phone      String?
  role       Role     @default(USER)
  avatarUrl  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  favorites  Favorite[]
  inquiries  Inquiry[]

  @@map("users")
}

enum Role {
  ADMIN
  USER
}

model Property {
  id             String   @id @default(cuid())
  externalId     String?  @unique  // ID de WASI
  title          String
  slug           String   @unique
  description    String?  @db.Text
  propertyType   String   // casa, depto, lote, local, oficina
  operation      String   // venta, alquiler, alquiler_temp
  price          Float?
  priceCurrency  String   @default("ARS")
  pricePeriod    String?  // mensual, anual
  areaTotal      Float?
  areaCovered    Float?
  rooms          Int?
  bedrooms       Int?
  bathrooms      Int?
  garages        Int?
  floor          Int?
  address        String?
  city           String?
  province       String?
  neighborhood   String?
  lat            Float?
  lng            Float?
  status         Status   @default(AVAILABLE)
  isPublished    Boolean  @default(false)
  isFeatured     Boolean  @default(false)
  viewsCount     Int      @default(0)
  crmSource      String?  // wasi
  crmUpdatedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  images    PropertyImage[]
  features  PropertyFeature[]
  favorites Favorite[]
  inquiries Inquiry[]
  views     PropertyView[]

  @@index([status, isPublished])
  @@index([propertyType, operation])
  @@index([city])
  @@index([price])
  @@map("properties")
}

enum Status {
  AVAILABLE
  RESERVED
  SOLD
  RENTED
  INACTIVE
}

model PropertyImage {
  id          String   @id @default(cuid())
  propertyId  String
  url         String
  urlBig      String?
  urlOriginal String?
  thumbnail   String?
  altText     String?
  orderIndex  Int      @default(0)
  isMain      Boolean  @default(false)
  createdAt   DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

model PropertyFeature {
  id          String  @id @default(cuid())
  propertyId  String
  category    String?
  name        String
  value       String?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_features")
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String
  createdAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("favorites")
}

model Inquiry {
  id          String        @id @default(cuid())
  propertyId  String?
  userId      String?
  name        String
  email       String
  phone       String?
  message     String        @db.Text
  source      String        @default("web")
  status      InquiryStatus @default(NEW)
  adminNotes  String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("inquiries")
}

enum InquiryStatus {
  NEW
  READ
  IN_PROGRESS
  CLOSED
}

model PropertyView {
  id          String   @id @default(cuid())
  propertyId  String
  userId      String?
  ipAddress   String?
  viewedAt    DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_views")
}

model SyncLog {
  id          String   @id @default(cuid())
  source      String   @default("wasi")
  status      String   // success, error
  synced      Int      @default(0)
  errors      Int      @default(0)
  message     String?
  createdAt   DateTime @default(now())

  @@map("sync_logs")
}
