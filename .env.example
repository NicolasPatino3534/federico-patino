# =============================================
# FEDERICO PATIÑO - Variables de entorno
# Copiar este archivo como .env.local y completar
# =============================================

# Base de datos (Neon.tech / Supabase / Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT Secret (generá uno con: openssl rand -base64 32)
JWT_SECRET="TU_JWT_SECRET_SUPER_SEGURO_AQUI"
JWT_EXPIRES_IN="7d"

# WASI CRM API
WASI_ID_COMPANY="24725603"
WASI_TOKEN="TU_NUEVO_TOKEN_AQUI"
WASI_BASE_URL="https://api.wasi.co/v1"

# Cloudinary (para imágenes subidas manualmente)
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# Email (SMTP — Brevo, SendGrid, Gmail, etc.)
# Si SMTP_HOST está vacío, las notificaciones se saltean silenciosamente.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Federico Patiño <noreply@federicopatino.com.ar>"
ADMIN_EMAIL="info@federicopatino.com.ar"

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER="543515956397"
NEXT_PUBLIC_WHATSAPP_MSG="Hola Federico, vi tu página y quería consultar sobre propiedades."

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY="AIza_TU_KEY_AQUI"

# URL del sitio (necesaria para Server Actions de sync)
NEXT_PUBLIC_SITE_URL="https://federicopatino.com.ar"
NEXT_PUBLIC_APP_URL="https://federicopatino.com.ar"

# Secret para el cron de sync WASI (generá con: openssl rand -hex 32)
# Vercel Cron lo envía automáticamente si está seteado en el proyecto
CRON_SECRET="TU_CRON_SECRET_AQUI"

# Sync WASI (en segundos, 1800 = 30 minutos)
WASI_SYNC_INTERVAL="1800"
